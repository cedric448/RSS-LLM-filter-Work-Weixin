# RSS 智能筛选推送系统 - 环境变量配置示例

# ============================================
# 今天看啥 API 配置
# ============================================
# 注册地址: https://www.jintiankansha.me/
API4_USER=your-email@example.com
API4_TOKEN=your-api-token-here

# ============================================
# 大模型 API 配置
# ============================================
# LLM API 地址和认证
LLM_API_URL=http://your-llm-api-endpoint
LLM_API_KEY=Bearer your-llm-api-key-here
LLM_MODEL=kimi-k2.5-ioa

# ============================================
# 企业微信配置
# ============================================
# 企业微信群机器人 Webhook 地址
# 获取方式: 企业微信群 -> 群设置 -> 群机器人 -> 添加机器人
WECHAT_WEBHOOK_KEY=your-webhook-key-here
# 完整 URL 格式: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key={WECHAT_WEBHOOK_KEY}

# ============================================
# Flask 管理后台配置
# ============================================
# Flask Secret Key (用于 session 加密)
# 生成方法: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=your-flask-secret-key-here

# 管理后台访问密码
RSS_ADMIN_AUTH_CODE=your-admin-password-here

# ============================================
# n8n 配置 (可选)
# ============================================
# 如果使用 n8n 工作流模式
N8N_API_KEY=your-n8n-api-key-here
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your-n8n-password-here
